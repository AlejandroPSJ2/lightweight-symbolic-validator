# Copy to .env and fill in your key (never commit .env)

# --- Gemini (recommended) ---
BENCHMARK_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-key-here
BENCHMARK_MODEL=gemini-2.5-flash
BENCHMARK_MAX_TOOL_ROUNDS=6
BENCHMARK_MAX_REPAIR_ROUNDS=1
# BENCHMARK_LETTERS_PREINJECT=1  # server-side tool injection (legacy; not LLM-invoked)

# --- OpenAI (alternative) ---
# BENCHMARK_PROVIDER=openai
# OPENAI_API_KEY=sk-your-key-here
# BENCHMARK_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1
